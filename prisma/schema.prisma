// Prisma schema mapped to remote MySQL database: sogbgtlg_sogbede

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Applications (core table — combines applicant + application data) ───

model Application {
  id               Int       @id @default(autoincrement())
  firstName        String    @map("first_name") @db.VarChar(100)
  lastName         String    @map("last_name") @db.VarChar(100)
  email            String    @unique @db.VarChar(255)
  phone            String?   @db.VarChar(50)
  city             String?   @db.VarChar(100)
  state            String?   @db.VarChar(100)
  country          String?   @db.VarChar(100)
  age              Int?
  occupation       String?   @db.VarChar(200)
  interests        String?   @db.Text
  filmingDate      DateTime? @map("filming_date") @db.Date
  partnerFirstName String?   @map("partner_first_name") @db.VarChar(100)
  partnerLastName  String?   @map("partner_last_name") @db.VarChar(100)
  mediaUrl         String?   @map("media_url") @db.VarChar(500)
  mediaFilename    String?   @map("media_filename") @db.VarChar(255)
  mediaSize        Int?      @map("media_size")
  mediaType        String?   @map("media_type") @db.VarChar(50)
  status           String    @default("pending") @db.VarChar(50)
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")
  adminNotes       String?   @map("admin_notes") @db.Text
  instagramHandle  String?   @map("instagram_handle") @db.VarChar(255)
  tiktokHandle     String?   @map("tiktok_handle") @db.VarChar(255)
  additionalNotes  String?   @map("additional_notes") @db.Text

  // Relations (logical - no FK constraints on MyISAM tables)
  visibility       AdminApplicationVisibility?
  categories       ApplicationCategory[]
  consentRecord    ConsentRecord?
  consentRequest   ConsentRequest?
  emailStatuses    CastingEmailDeliveryStatus[]
  episodeMembers   EpisodeMember[]

  @@map("applications")
}

// ─── Admin Application Visibility ───

model AdminApplicationVisibility {
  id            Int       @id @default(autoincrement())
  applicationId Int       @unique @map("application_id")
  isHidden      Boolean   @default(false) @map("is_hidden")
  hiddenAt      DateTime? @map("hidden_at")
  hiddenReason  String?   @map("hidden_reason") @db.VarChar(255)
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at")

  application   Application @relation(fields: [applicationId], references: [id])

  @@map("admin_application_visibility")
}

// ─── Admin Settings (key-value JSON store) ───

model AdminSetting {
  id           Int       @id @default(autoincrement())
  settingKey   String    @unique @map("setting_key") @db.VarChar(100)
  settingValue String?   @map("setting_value") @db.LongText
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("admin_settings")
}

// ─── Categories ───

model Category {
  id           Int       @id @default(autoincrement())
  categoryName String    @unique @map("category_name") @db.VarChar(255)
  categorySlug String    @unique @map("category_slug") @db.VarChar(255)
  description  String?   @db.Text
  colorCode    String?   @default("#3b82f6") @map("color_code") @db.VarChar(7)
  isExclusive  Boolean   @default(false) @map("is_exclusive")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at")

  applications ApplicationCategory[]

  @@map("categories")
}

// ─── Application Categories (many-to-many join) ───

model ApplicationCategory {
  id            Int       @id @default(autoincrement())
  applicationId Int       @map("application_id")
  categoryId    Int       @map("category_id")
  assignedAt    DateTime? @default(now()) @map("assigned_at")
  assignedBy    String    @default("system") @map("assigned_by") @db.VarChar(255)

  application   Application @relation(fields: [applicationId], references: [id])
  category      Category    @relation(fields: [categoryId], references: [id])

  @@unique([applicationId, categoryId])
  @@map("application_categories")
}

// ─── Casting Email Delivery Status ───

model CastingEmailDeliveryStatus {
  recipientKey  String    @id @map("recipient_key") @db.VarChar(255)
  applicationId Int?      @map("application_id")
  email         String    @db.VarChar(255)
  lastStatus    String    @default("failed") @map("last_status") @db.VarChar(10)
  lastError     String?   @map("last_error") @db.Text
  lastSubject   String?   @map("last_subject") @db.VarChar(255)
  attemptCount  Int       @default(0) @map("attempt_count")
  successCount  Int       @default(0) @map("success_count")
  lastAttemptAt DateTime? @map("last_attempt_at")
  lastSuccessAt DateTime? @map("last_success_at")
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at")

  application   Application? @relation(fields: [applicationId], references: [id])

  @@map("casting_email_delivery_status")
}

// ─── Consent Records ───

model ConsentRecord {
  id              Int       @id @default(autoincrement())
  applicationId   Int       @unique @map("application_id")
  consentSignedAt DateTime? @default(now()) @map("consent_signed_at")
  lastFourDigits  String?   @map("last_four_digits") @db.VarChar(4)
  createdAt       DateTime? @default(now()) @map("created_at")

  application     Application @relation(fields: [applicationId], references: [id])

  @@map("consent_records")
}

// ─── Consent Requests ───

model ConsentRequest {
  id            Int       @id @default(autoincrement())
  applicationId Int       @unique @map("application_id")
  status        String    @default("pending") @db.VarChar(20)
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at")

  application   Application @relation(fields: [applicationId], references: [id])

  @@map("consent_requests")
}

// ─── Episodes ───

model Episode {
  id            Int       @id @default(autoincrement())
  episodeNumber Int?      @unique @map("episode_number")
  title         String?   @db.VarChar(255)
  shootDate     DateTime? @map("shoot_date") @db.Date
  status        String    @default("planned") @db.VarChar(20)
  notes         String?   @db.Text
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at")

  members       EpisodeMember[]

  @@map("episodes")
}

// ─── Episode Members ───

model EpisodeMember {
  id               Int       @id @default(autoincrement())
  episodeId        Int       @map("episode_id")
  applicationId    Int?      @map("application_id")
  fullNameSnapshot String    @map("full_name_snapshot") @db.VarChar(255)
  emailSnapshot    String?   @map("email_snapshot") @db.VarChar(255)
  photoUrlSnapshot String?   @map("photo_url_snapshot") @db.Text
  teamNumber       Int       @map("team_number") @db.TinyInt
  seatNumber       Int       @map("seat_number") @db.TinyInt
  createdAt        DateTime? @default(now()) @map("created_at")

  episode          Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  application      Application? @relation(fields: [applicationId], references: [id])

  @@unique([episodeId, teamNumber, seatNumber])
  @@unique([episodeId, applicationId])
  @@map("episode_members")
}

// ─── Filming Calendar ───

model FilmingCalendar {
  id               Int       @id @default(autoincrement())
  date             DateTime  @unique @db.Date
  status           String    @default("available") @db.VarChar(20)
  capacityLimit    Int?      @map("capacity_limit")
  isManualOverride Boolean   @default(true) @map("is_manual_override")
  notes            String?   @db.Text
  createdAt        DateTime? @default(now()) @map("created_at")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("filming_calendar")
}

// ─── Admin Users (new table — will be created via db push) ───

model Admin {
  id        Int       @id @default(autoincrement())
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  name      String    @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("admins")
}
